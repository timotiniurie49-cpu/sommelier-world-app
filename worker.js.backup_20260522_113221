async function fetchLatestNewsFromRSS() {
  for (const source of RSS_SOURCES) {
    try {
      const response = await fetch(source.url, {
        headers: { 'User-Agent': 'Mozilla/5.0 SommelierWorld/1.0' },
        signal: AbortSignal.timeout(8000)
      });
      
      if (!response.ok) {
        console.error(`RSS fetch failed: ${source.name} ${response.status}`);
        continue;
      }
      
      const xml = await response.text();
      const news = parseRSSFeed(xml, source.name);
      
      if (news && news.originalTitle && news.originalText) {
        console.log(`Successfully fetched from: ${source.name}`);
        return news;
      }
    } catch (error) {
      console.error(`Error fetching ${source.name}:`, error.message);
      continue;
    }
  }
  
  console.error('All RSS sources failed');
  return null;
}

function parseRSSFeed(xml, sourceName) {
  try {
    const itemMatch = xml.match(/<item>(.*?)<\/item>/s);
    if (!itemMatch) {
      console.error(`No <item> found in ${sourceName}`);
      return null;
    }
    
    const item = itemMatch[1];
    
    const titleMatch = item.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>|<title>(.*?)<\/title>/s);
    const title = titleMatch ? (titleMatch[1] || titleMatch[2]).trim() : '';
    
    const descMatch = item.match(/<description><!\[CDATA\[(.*?)\]\]><\/description>|<description>(.*?)<\/description>/s);
    const description = descMatch ? (descMatch[1] || descMatch[2]).trim() : '';
    
    const linkMatch = item.match(/<link>(.*?)<\/link>/);
    const link = linkMatch ? linkMatch[1].trim() : '';
    
    const dateMatch = item.match(/<pubDate>(.*?)<\/pubDate>/);
    const pubDate = dateMatch ? dateMatch[1].trim() : new Date().toISOString();
    
    if (!title || !description) {
      console.error(`Missing title or description in ${sourceName}`);
      return null;
    }
    
    const cleanDescription = description
      .replace(/<[^>]*>/g, '')
      .replace(/&nbsp;/g, ' ')
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .trim();
    
    return {
      originalTitle: title.slice(0, 180),
      originalText: cleanDescription.slice(0, 600),
      sourceUrl: link,
      sourceName: sourceName,
      publishDate: pubDate
    };
  } catch (error) {
    console.error(`Parse error for ${sourceName}:`, error.message);
    return null;
  }
}

async function rewriteNewsWithAI(env, originalNews) {
  const groqKey = getGroqKey(env);
  
  if (!groqKey) {
    console.error('GROQ_API_KEY not configured');
    return {
      title: originalNews.originalTitle.slice(0, 80),
      excerpt: originalNews.originalText.slice(0, 200) + '...',
      sourceUrl: originalNews.sourceUrl,
      sourceName: originalNews.sourceName,
      publishDate: new Date().toISOString(),
      originalTitle: originalNews.originalTitle,
      error: 'AI not configured'
    };
  }

  const prompt = `Sei un sommelier esperto ed elegante.

NOTIZIA ORIGINALE:
Titolo: ${originalNews.originalTitle}
Testo: ${originalNews.originalText}
Fonte: ${originalNews.sourceName}

COMPITO:
Riscrivi questa notizia in modo elegante e professionale per un pubblico enologico italiano.

REGOLE FERREE:
- Titolo: max 80 caratteri, evocativo ma preciso
- Riassunto: max 200 caratteri, denso e leggibile
- Tono: elegante, bordeaux, oro, professionale
- NON inventare fatti
- Mantieni l'informazione chiave ma rendila più raffinata
- Zero emoji, zero eccessi

RISPONDI SOLO IN JSON (zero markdown, zero testo fuori):
{"title": "titolo elegante qui", "excerpt": "riassunto elegante qui"}`;

  try {
    const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${groqKey}`
      },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',
        messages: [
          { role: 'system', content: 'Sei un sommelier professionista. Rispondi SOLO con JSON valido.' },
          { role: 'user', content: prompt }
        ],
        temperature: 0.7,
        max_tokens: 400
      })
    });
    
    if (!response.ok) {
      const errorText = await response.text().catch(() => '');
      console.error(`Groq API error ${response.status}:`, errorText.slice(0, 200));
      throw new Error(`Groq ${response.status}`);
    }
    
    const data = await response.json();
    const aiText = data.choices?.[0]?.message?.content || '';
    
    if (!aiText) {
      throw new Error('Empty AI response');
    }
    
    const jsonMatch = aiText.match(/\{[\s\S]*\}/);
    if (!jsonMatch) {
      console.error('No JSON found in AI response:', aiText.slice(0, 200));
      throw new Error('No JSON in response');
    }
    
    const cleanJson = sanitizeJsonText(jsonMatch[0]);
    const aiResult = JSON.parse(cleanJson);
    
    if (!aiResult.title || !aiResult.excerpt) {
      throw new Error('Missing fields in AI JSON');
    }
    
    return {
      title: aiResult.title.slice(0, 80),
      excerpt: aiResult.excerpt.slice(0, 200),
      sourceUrl: originalNews.sourceUrl,
      sourceName: originalNews.sourceName,
      publishDate: new Date().toISOString(),
      originalTitle: originalNews.originalTitle
    };
    
  } catch (error) {
    console.error('AI rewrite failed:', error.message);
    
    return {
      title: originalNews.originalTitle.slice(0, 80),
      excerpt: originalNews.originalText.slice(0, 200) + '...',
      sourceUrl: originalNews.sourceUrl,
      sourceName: originalNews.sourceName,
      publishDate: new Date().toISOString(),
      originalTitle: originalNews.originalTitle,
      error: error.message
    };
  }
}

async function generateDailyNews(env) {
  try {
    console.log('Starting daily news generation...');
    
    const latestNews = await fetchLatestNewsFromRSS();
    
    if (!latestNews) {
      console.error('No news found from any RSS source');
      return { success: false, error: 'No news available' };
    }
    
    console.log('Found news:', latestNews.originalTitle);
    
    const rewrittenNews = await rewriteNewsWithAI(env, latestNews);
    
    console.log('Rewritten news:', rewrittenNews.title);
    
    const kv = getStateKV(env);
    if (!kv) {
      console.error('KV storage not configured');
      return { success: false, error: 'KV not configured' };
    }
    
    const today = new Date().toISOString().split('T')[0];
    
    await kvPutJson(kv, `news:${today}`, rewrittenNews);
    await kvPutJson(kv, 'news:latest', rewrittenNews);
    
    console.log(`News saved for ${today}`);
    
    return {
      success: true,
      date: today,
      title: rewrittenNews.title,
      source: rewrittenNews.sourceName
    };
    
  } catch (error) {
    console.error('Daily news generation failed:', error.message, error.stack);
    return {
      success: false,
      error: error.message
    };
  }
}

async function getDailyNews(env, dateKey) {
  const kv = getStateKV(env);
  
  if (!kv) {
    return {
      error: 'KV storage not configured',
      title: 'Notizie non disponibili',
      excerpt: 'Il sistema di notizie non e configurato correttamente.',
      sourceUrl: '',
      sourceName: 'Sistema',
      publishDate: new Date().toISOString()
    };
  }
  
  const today = dateKey || new Date().toISOString().split('T')[0];
  
  let news = await kvGetJson(kv, `news:${today}`);
  if (news) {
    console.log(`Found news for ${today}`);
    return news;
  }
  
  console.log(`No news for ${today}, trying latest...`);
  news = await kvGetJson(kv, 'news:latest');
  if (news) {
    console.log('Found latest news');
    return news;
  }
  
  console.log('No news in KV, generating now...');
  await generateDailyNews(env);
  
  news = await kvGetJson(kv, 'news:latest');
  if (news) return news;
  
  return {
    error: 'News generation failed',
    title: 'Notizie non disponibili',
    excerpt: 'Non siamo riusciti a recuperare le notizie del giorno.',
    sourceUrl: '',
    sourceName: 'Sistema',
    publishDate: new Date().toISOString()
  };
}

async function handleDailyNewsRequest(request, env) {
  const corsHeaders = {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
    'Access-Control-Allow-Headers': 'Content-Type',
  };
  
  if (request.method === 'OPTIONS') {
    return new Response(null, { headers: corsHeaders });
  }
  
  try {
    const url = new URL(request.url);
    const dateParam = url.searchParams.get('date');
    
    const news = await getDailyNews(env, dateParam);
    
    return new Response(JSON.stringify({
      success: true,
      news: news
    }), {
      headers: {
        'Content-Type': 'application/json',
        ...corsHeaders
      }
    });
    
  } catch (error) {
    console.error('Daily news request error:', error.message);
    
    return new Response(JSON.stringify({
      success: false,
      error: error.message
    }), {
      status: 500,
      headers: {
        'Content-Type': 'application/json',
        ...corsHeaders
      }
    });
  }
}

